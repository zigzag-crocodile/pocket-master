# ============ AI 模型（通用 OpenAI 兼容）============
# 配好这三项，AI 就真实回答；留空则走 Mock 模式。
# 推荐 DeepSeek（国内易申请、便宜、质量好）：
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
#
# 换其它模型只改这三项即可（示例）：
#   DeepSeek : LLM_MODEL=deepseek-chat            LLM_BASE_URL=https://api.deepseek.com
#   Kimi     : LLM_MODEL=moonshot-v1-8k           LLM_BASE_URL=https://api.moonshot.cn/v1
#   智谱 GLM : LLM_MODEL=glm-4-flash              LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   通义千问 : LLM_MODEL=qwen-plus                LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   Doubao   : LLM_MODEL=doubao-seed-2.0-lite     LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ============ 语音转写（OpenAI 兼容 /audio/transcriptions）============
# 配好则支持「录音/上传音频 → 转文字」；留空则录音/音频功能提示未配置。
# 推荐 Groq Whisper（有免费额度）：
STT_API_KEY=
STT_MODEL=whisper-large-v3-turbo
STT_BASE_URL=https://api.groq.com/openai/v1
# 仅本地：若你所在地区直连被转写服务封锁，可设代理出网（如 clash）。
# ⚠️ 部署到 Vercel 等海外环境时【不要】设置 STT_PROXY。
# STT_PROXY=http://127.0.0.1:7897

# ============ Supabase（登录 + 数据持久化）============
# 留空则登录走 demo 模式、数据存在浏览器内存（刷新即丢）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============ 管理后台 /admin ============
# 允许访问 /admin 看全站数据的邮箱（逗号分隔多个）。留空则 /admin 拒绝所有人。
ADMIN_EMAIL=
